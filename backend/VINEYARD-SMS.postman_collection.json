              "raw": "{\n  \"firstName\": \"John\",\n  \"lastName\": \"Doe\",\n  \"admissionNumber\": \"VIN/2026/0001\",\n  \"gender\": \"male\",\n  \"dateOfBirth\": \"2010-05-15\",\n  \"curriculum\": \"8-4-4\",\n  \"currentGrade\": \"Form 1\",\n  \"stream\": \"A\",\n  \"boardingStatus\": \"boarding\",\n  \"guardians\": [\n    {\n      \"relationship\": \"mother\",\n      \"isPrimary\": true,\n      \"occupation\": \"Teacher\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "http://localhost:5000/api/students",
              "protocol": "http",
              "host": ["localhost"],
              "port": "5000",
              "path": ["api", "students"]
            }
          }
        },
