# ═══════════════════════════════════════════════════════════════
# VINEYARD-SMS Backend Configuration
# ═══════════════════════════════════════════════════════════════

# 📊 DATABASE CONFIGURATION
# ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=farm_sms
DB_USER=postgres
DB_PASSWORD=12345

# 🔐 JWT AUTHENTICATION
# ─────────────────────────────────────────────────────────────────
JWT_SECRET=vineyard-sms-dev-key-2024-change-in-production-please

# 🚀 SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
BACKEND_URL=http://localhost:5000

# 🌐 FRONTEND CONFIGURATION
# ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ═══════════════════════════════════════════════════════════════
# 💳 M-PESA CONFIGURATION (IMPORTANT: Setup required)
# ═══════════════════════════════════════════════════════════════
#
# 1. Visit: https://developer.safaricom.co.ke/
# 2. Create an account and app
# 3. Copy credentials below
# 4. For Sandbox: Use test credentials provided
# 5. For Production: Contact Safaricom business team
#
# ─────────────────────────────────────────────────────────────────

# Environment: sandbox or production
MPESA_ENV=sandbox

# Consumer Key - Get from Daraja Portal
MPESA_CONSUMER_KEY=

# Consumer Secret - Get from Daraja Portal  
MPESA_CONSUMER_SECRET=

# Passkey - Get from Daraja Portal (different from shortcode password!)
MPESA_PASSKEY=

# Business Shortcode - 174379 for sandbox, your code for production
MPESA_SHORTCODE=174379

# ═══════════════════════════════════════════════════════════════
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_PASSKEY=your_passkey
MPESA_SHORTCODE=your_shortcode

# Email Configuration (Optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# SMS Configuration (Optional)
SMS_PROVIDER=africastalking
SMS_API_KEY=your_api_key
SMS_USERNAME=your_username